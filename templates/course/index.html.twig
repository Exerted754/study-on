{% extends 'base.html.twig' %}

{% block title %}Курсы / StudyOn{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Курсы</h1>
        {% if is_granted('ROLE_SUPER_ADMIN') %}
            <a href="{{ path('app_course_new') }}" class="btn btn-primary">Добавить курс</a>
        {% endif %}
    </div>

    {% if courses|length > 0 %}
        <div class="list-group">
            {% for course in courses %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="mb-1">
                                <a href="{{ path('app_course_show', {'id': course.id}) }}" class="text-decoration-none">
                                    {{ course.title }}
                                </a>
                            </h5>

                            {% if course.description %}
                                <p class="mb-1 text-muted">{{ course.description }}</p>
                            {% endif %}

                            {% set billingCourse = billingCourses[course.code] ?? null %}

                            {% if billingCourse %}
                                <div class="mt-2">
                                    {% if billingCourse.type == 'free' %}
                                        <span class="badge text-bg-success">Бесплатно</span>
                                    {% elseif billingCourse.type == 'buy' %}
                                        <span class="badge text-bg-primary">Покупка</span>
                                        <span class="text-muted">{{ billingCourse.price }} ₽</span>
                                    {% elseif billingCourse.type == 'rent' %}
                                        <span class="badge text-bg-warning">Аренда</span>
                                        <span class="text-muted">{{ billingCourse.price }} ₽</span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>

                        {% if is_granted('ROLE_SUPER_ADMIN') %}
                            <a href="{{ path('app_course_edit', {'id': course.id}) }}" class="btn btn-sm btn-outline-secondary">
                            Редактировать
                        </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">
            Курсы пока не добавлены.
        </div>
    {% endif %}
{% endblock %}
