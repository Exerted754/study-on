{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} / StudyOn{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-2">{{ course.title }}</h1>

            {% if course.description %}
                <p class="text-muted mb-0">{{ course.description }}</p>
            {% endif %}
        </div>

        {% if is_granted('ROLE_SUPER_ADMIN') %}
            <div class="d-flex gap-2">
                <a href="{{ path('app_course_edit', {'id': course.id}) }}" class="btn btn-outline-secondary">Редактировать</a>
                <a href="{{ path('app_lesson_new', {'course_id': course.id}) }}" class="btn btn-primary">Добавить урок</a>
            </div>
        {% endif %}
    </div>

    <div class="mb-4">
        <a href="{{ path('app_course_index') }}" class="btn btn-outline-secondary">К списку курсов</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h4 mb-3">Уроки</h2>

            {% if course.lessons|length > 0 %}
                <div class="list-group">
                    {% for lesson in course.lessons %}
                        <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>{{ lesson.title }}</span>
                            <span class="badge text-bg-secondary">{{ lesson.number }}</span>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info mb-0">
                    Уроков пока нет.
                </div>
            {% endif %}
        </div>
    </div>

    {% if is_granted('ROLE_SUPER_ADMIN') %}
        {{ include('course/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
