{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} / StudyOn{% endblock %}

{% block body %}
    <h1>{{ course.title }}</h1>

    {% if course.description %}
        <p>{{ course.description }}</p>
    {% endif %}

    <h2>Уроки</h2>

    {% if course.lessons|length > 0 %}
        <ul>
            {% for lesson in course.lessons %}
                <li>
                    <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">
                        {{ lesson.title }}
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>Уроков пока нет.</p>
    {% endif %}

    <p>
        <a href="{{ path('app_course_index') }}">Вернуться к списку</a>
    </p>

    <p>
        <a href="{{ path('app_course_edit', {'id': course.id}) }}">Редактировать</a>
    </p>

    <p>
        <a href="{{ path('app_lesson_new', {'course_id': course.id}) }}">Добавить урок</a>
    </p>

    {{ include('course/_delete_form.html.twig') }}
{% endblock %}
