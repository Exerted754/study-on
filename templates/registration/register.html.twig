{% extends 'base.html.twig' %}

{% block title %}Регистрация / StudyOn{% endblock %}

{% block body %}
    <h1 class="mb-4">Регистрация</h1>

    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}

                <div class="mb-3">
                    {{ form_label(form.email, 'Email') }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.password, 'Пароль') }}
                    {{ form_widget(form.password, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.password) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.passwordRepeat, 'Повторите пароль') }}
                    {{ form_widget(form.passwordRepeat, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.passwordRepeat) }}
                </div>

                <button class="btn btn-primary">Зарегистрироваться</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
