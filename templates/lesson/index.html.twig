{% extends 'base.html.twig' %}

{% block title %}Уроки / StudyOn{% endblock %}

{% block body %}
    <h1>Уроки</h1>

    {% if lessons|length > 0 %}
        <ul>
            {% for lesson in lessons %}
                <li>
                    <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">
                        {{ lesson.title }}
                    </a>
                    — {{ lesson.course.title }}
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>Уроки пока не добавлены.</p>
    {% endif %}

    <p>
        <a href="{{ path('app_lesson_new') }}">Добавить новый урок</a>
    </p>
{% endblock %}
