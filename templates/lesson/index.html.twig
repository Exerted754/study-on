{% extends 'base.html.twig' %}

{% block title %}Уроки / StudyOn{% endblock %}

{% block body %}
    <h1 class="mb-4">Уроки</h1>

    {% if lessons|length > 0 %}
        <div class="list-group">
            {% for lesson in lessons %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="mb-1">
                                <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="text-decoration-none">
                                    {{ lesson.title }}
                                </a>
                            </h5>

                            <p class="mb-1 text-muted">
                                Курс:
                                <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}" class="text-decoration-none">
                                    {{ lesson.course.title }}
                                </a>
                            </p>
                        </div>

                        {% if is_granted('ROLE_SUPER_ADMIN') %}
                            <a href="{{ path('app_lesson_edit', {'id': lesson.id}) }}" class="btn btn-sm btn-outline-secondary">
                                Редактировать
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">
            Уроки пока не добавлены.
        </div>
    {% endif %}
{% endblock %}
