{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} / {{ lesson.course.title }} / StudyOn{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-2">{{ lesson.title }}</h1>
            <p class="text-muted mb-0">
                Курс:
                <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}" class="text-decoration-none">
                    {{ lesson.course.title }}
                </a>
            </p>
        </div>

        {% if is_granted('ROLE_SUPER_ADMIN') %}
            <a href="{{ path('app_lesson_edit', {'id': lesson.id}) }}" class="btn btn-outline-secondary">
                Редактировать
            </a>
        {% endif %}
    </div>

    <div class="mb-4">
        <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}" class="btn btn-outline-secondary">
            Вернуться к курсу
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h4 mb-3">Содержимое урока</h2>
            <p class="mb-0">{{ lesson.content|nl2br }}</p>
        </div>
    </div>

    {% if is_granted('ROLE_SUPER_ADMIN') %}
        {{ include('lesson/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
